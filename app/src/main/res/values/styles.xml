<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 16sp + weight (not size) marks section labels, per M3 type roles. -->
    <style name="SectionHeader">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginTop">16dp</item>
    </style>

    <!-- Shared transport-button bundle: 64dp target, spaced ≥8dp apart. -->
    <style name="TransportButton" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:layout_height">64dp</item>
        <item name="android:minWidth">80dp</item>
        <item name="android:textSize">24sp</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginEnd">4dp</item>
    </style>

    <!-- The one high-emphasis action on the screen. -->
    <style name="PrimaryAction" parent="Widget.AppCompat.Button.Colored">
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Caption">
        <item name="android:textSize">12sp</item>
    </style>
</resources>
