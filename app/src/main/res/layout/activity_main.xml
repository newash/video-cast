<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Fixed header: the cast icon must never scroll out of reach. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textAppearance="?android:attr/textAppearanceMedium" />

        <androidx.mediarouter.app.MediaRouteButton
            android:id="@+id/cast_button"
            android:layout_width="48dp"
            android:layout_height="48dp" />
    </LinearLayout>

    <!-- Setup zone: steps in task order, all controls always visible. -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/step_video"
                style="@style/SectionHeader"
                android:text="@string/step_video" />

            <TextView
                android:id="@+id/video_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@string/no_video" />

            <Button
                android:id="@+id/pick_video"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/pick_video" />

            <TextView
                android:id="@+id/step_subtitles"
                style="@style/SectionHeader"
                android:text="@string/step_subtitles" />

            <!-- minHeight reserves the ✕/spinner space so their appearance doesn't shift the row. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="48dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/subtitle_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@string/no_subtitles" />

                <ProgressBar
                    android:id="@+id/extract_progress"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/clear_subtitle"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/clear_subtitle"
                    android:textSize="18sp"
                    android:text="✕"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/pick_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="12sp"
                    android:autoSizeMaxTextSize="14sp"
                    android:text="@string/pick_file" />

                <Button
                    android:id="@+id/search_subtitles"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:enabled="false"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="12sp"
                    android:autoSizeMaxTextSize="14sp"
                    android:text="@string/search_online" />

                <Button
                    android:id="@+id/embedded_subtitles"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:enabled="false"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="12sp"
                    android:autoSizeMaxTextSize="14sp"
                    android:text="@string/embedded_subtitles" />
            </LinearLayout>

            <TextView
                android:id="@+id/step_chromecast"
                style="@style/SectionHeader"
                android:text="@string/step_chromecast" />

            <TextView
                android:id="@+id/device_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingBottom="16dp"
                android:text="@string/not_connected" />
        </LinearLayout>
    </ScrollView>

    <!-- Pinned panel: everything tapped repeatedly lives in the thumb zone. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/now_playing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/controls_hint"
                style="@style/Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/leftover_media_hint"
                android:visibility="gone" />

            <SeekBar
                android:id="@+id/seek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:paddingVertical="8dp"
                android:max="1000" />

            <TextView
                android:id="@+id/time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:fontFeatureSettings="tnum"
                android:textSize="18sp"
                tools:text="0:00 / 0:00" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/volume" />

                <SeekBar
                    android:id="@+id/volume"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="48dp"
                    android:max="100" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/rewind"
                    style="@style/TransportButton"
                    android:text="↺10" />

                <Button
                    android:id="@+id/play_pause"
                    style="@style/TransportButton"
                    android:minWidth="96dp"
                    android:textSize="28sp"
                    android:text="▶" />

                <Button
                    android:id="@+id/forward"
                    style="@style/TransportButton"
                    android:text="30↻" />

                <!-- Stop is destructive: quarantined from the skip cluster. -->
                <Button
                    android:id="@+id/stop"
                    style="@style/TransportButton"
                    android:layout_marginStart="24dp"
                    android:textColor="?attr/colorError"
                    android:text="■" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/cast"
            style="@style/PrimaryAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:text="@string/play_on_tv" />
    </LinearLayout>
</LinearLayout>
